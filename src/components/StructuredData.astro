---
import { SITE_AUTHOR, SITE_LOGO, SITE_PUBLISHER, SITE_TITLE } from '@/consts';

type ListItem = {
    name: string;
    item: string;
};

interface Props {
    type?: 'website' | 'article';
    articleType?: 'BlogPosting' | 'Article' | 'TechArticle' | 'HowTo';
    canonical?: string;
    title?: string;
    description?: string;
    image?: string;
    datePublished?: Date | string;
    dateModified?: Date | string;
    tags?: Array<string | number>;
    category?: string;
    breadcrumbs?: ListItem[];
}

const {
    type = 'website',
    articleType = 'BlogPosting',
    canonical,
    title,
    description,
    image,
    datePublished,
    dateModified,
    tags = [],
    category,
    breadcrumbs = [],
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const currentUrl = new URL(canonical ?? Astro.url.pathname, Astro.site).toString();

const normalizeImage = (value?: string) => {
    if (!value) return undefined;
    if (value.startsWith('http://') || value.startsWith('https://')) return value;
    return new URL(value, Astro.site).toString();
};

const normalizedImage = normalizeImage(image);

const websiteSchema = {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE_TITLE,
    url: siteUrl,
    inLanguage: 'ko-KR',
};

const personSchema =
    type === 'website' && new URL(currentUrl).pathname === '/'
        ? {
              '@context': 'https://schema.org',
              '@type': 'Person',
              name: SITE_AUTHOR,
              url: siteUrl,
          }
        : null;

const breadcrumbSchema =
    breadcrumbs.length > 0
        ? {
              '@context': 'https://schema.org',
              '@type': 'BreadcrumbList',
              itemListElement: breadcrumbs.map((item, index) => ({
                  '@type': 'ListItem',
                  position: index + 1,
                  name: item.name,
                  item: item.item,
              })),
          }
        : null;

const articleSchema =
    type === 'article'
        ? {
              '@context': 'https://schema.org',
              '@type': articleType,
              headline: title,
              description,
              mainEntityOfPage: currentUrl,
              url: currentUrl,
              image: normalizedImage ? [normalizedImage] : undefined,
              datePublished: datePublished
                  ? new Date(datePublished).toISOString()
                  : undefined,
              dateModified: dateModified
                  ? new Date(dateModified).toISOString()
                  : datePublished
                    ? new Date(datePublished).toISOString()
                    : undefined,
              author: {
                  '@type': 'Person',
                  name: SITE_AUTHOR,
              },
              publisher: {
                  '@type': 'Organization',
                  name: SITE_PUBLISHER,
                  logo: {
                      '@type': 'ImageObject',
                      url: new URL(SITE_LOGO, Astro.site).toString(),
                  },
              },
              articleSection: category,
              keywords:
                  tags.length > 0
                      ? tags.map((tag) => String(tag)).join(', ')
                      : undefined,
              inLanguage: 'ko-KR',
          }
        : null;

const schemas = [
    type === 'website' ? websiteSchema : null,
    personSchema,
    breadcrumbSchema,
    articleSchema,
].filter(Boolean);
---

{
    schemas.map((schema) => (
        <script type='application/ld+json' set:html={JSON.stringify(schema)} />
    ))
}
