---
import StructuredData from './StructuredData.astro';
import { SITE_DEFAULT_IMAGE, SITE_TITLE } from '@/consts';
import { getPublicTags } from '@/utils/tags';

interface Props {
    title: string;
    description?: string;
    canonical?: string;
    image?: string;
    type?: 'website' | 'article';
    schemaType?: 'website' | 'article';
    articleType?: 'BlogPosting' | 'Article' | 'TechArticle' | 'HowTo';
    breadcrumbs?: {
        name: string;
        item: string;
    }[];
    datePublished?: Date | string;
    dateModified?: Date | string;
    publishedTime?: Date | string;
    modifiedTime?: Date | string;
    tags?: Array<string | number>;
    category?: string;
    noindex?: boolean;
    nofollow?: boolean;
    titleTemplate?: boolean;
}

const {
    title: defaultTitle,
    description,
    canonical,
    image,
    type,
    schemaType: legacySchemaType,
    articleType,
    breadcrumbs = [],
    datePublished,
    dateModified,
    publishedTime,
    modifiedTime,
    tags = [],
    category,
    noindex = false,
    nofollow = false,
    titleTemplate = true,
} = Astro.props as Props;

const schemaType = type ?? legacySchemaType ?? 'website';
const resolvedPublishedTime = publishedTime ?? datePublished;
const resolvedModifiedTime = modifiedTime ?? dateModified;
const title = titleTemplate
    ? defaultTitle
        ? `${defaultTitle} - ${SITE_TITLE}`
        : SITE_TITLE
    : defaultTitle;
const canonicalURL = new URL(canonical ?? Astro.url.pathname, Astro.site);

const robots = `${noindex ? 'noindex' : 'index'},${nofollow ? 'nofollow' : 'follow'}`;
const siteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION?.trim();

function toAbsoluteUrl(src?: string) {
    if (!src) return new URL(SITE_DEFAULT_IMAGE, Astro.site).toString();
    if (src.startsWith('http://') || src.startsWith('https://')) return src;
    return new URL(src, Astro.site).toString();
}

const ogImage = toAbsoluteUrl(image);
const seoTags = getPublicTags(tags).map((tag) => tag.label);
const keywords = seoTags.join(', ');
---

<!-- Global Metadata -->
<meta charset='utf-8' />
<meta name='viewport' content='width=device-width,initial-scale=1' />
<link rel='icon' href='/images/site/akita-inu.png' />
<link rel='sitemap' href='/sitemap-index.xml' />
<link
    rel='alternate'
    type='application/rss+xml'
    title={SITE_TITLE}
    href={new URL('rss.xml', Astro.site)}
/>
<meta name='generator' content={Astro.generator} />
<meta name='robots' content={robots} />
{
    siteVerification && (
        <meta name='google-site-verification' content={siteVerification} />
    )
}

<!-- Font preloads -->
<link
    rel='preload'
    href='/fonts/atkinson-regular.woff'
    as='font'
    type='font/woff'
    crossorigin
/>
<link
    rel='preload'
    href='/fonts/atkinson-bold.woff'
    as='font'
    type='font/woff'
    crossorigin
/>

<!-- Canonical URL -->
<link rel='canonical' href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name='title' content={title} />
{description && <meta name='description' content={description} />}
{keywords && <meta name='keywords' content={keywords} />}

<!-- Open Graph / Facebook -->
<meta property='og:type' content={schemaType === 'article' ? 'article' : 'website'} />
<meta property='og:url' content={canonicalURL} />
<meta property='og:site_name' content={SITE_TITLE} />
<meta property='og:locale' content='ko_KR' />
<meta property='og:title' content={title} />
{description && <meta property='og:description' content={description} />}
<meta property='og:image' content={ogImage} />
{
    schemaType === 'article' && resolvedPublishedTime && (
        <meta
            property='article:published_time'
            content={new Date(resolvedPublishedTime).toISOString()}
        />
    )
}
{
    schemaType === 'article' && resolvedModifiedTime && (
        <meta
            property='article:modified_time'
            content={new Date(resolvedModifiedTime).toISOString()}
        />
    )
}
{
    schemaType === 'article' && category && (
        <meta property='article:section' content={category} />
    )
}
{
    schemaType === 'article' &&
        seoTags.map((tag) => <meta property='article:tag' content={tag} />)
}

<!-- Twitter -->
<meta name='twitter:card' content='summary_large_image' />
<meta name='twitter:url' content={canonicalURL.toString()} />
<meta name='twitter:title' content={title} />
{description && <meta name='twitter:description' content={description} />}
<meta name='twitter:image' content={ogImage} />

<StructuredData
    type={schemaType}
    articleType={articleType}
    canonical={canonicalURL.toString()}
    title={defaultTitle}
    description={description}
    image={ogImage}
    breadcrumbs={breadcrumbs}
    datePublished={resolvedPublishedTime}
    dateModified={resolvedModifiedTime}
    tags={seoTags}
    category={category}
/>
