---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import generatePlaceholder from '../utils/placeholderThumbnail.js';
import { sortDisplayTags } from '@/utils/tags';

interface Props {
    entries?: CollectionEntry<'blog'>[];
    basePath?: string;
    showViews?: boolean;
}

const { entries = [], basePath = '/article', showViews = true }: Props = Astro.props;

// GA page views (generated at build time). If the file doesn't exist, treat as empty.
type GaView = { path: string; totalCount: string };
let gaViews: GaView[] = [];
try {
    gaViews = ((await import('../data/ga-views.json')).default ?? []) as GaView[];
} catch {
    gaViews = [];
}

const viewMap = new Map<string, number>(
    gaViews.map((v) => [v.path, Number(v.totalCount) || 0]),
);

const normalizeHref = (p) => {
    if (!p) return p;
    // external URLs -> leave as-is
    if (/^https?:\/\//i.test(p) || /^\/\//.test(p)) return p;
    let out = p;
    if (!out.startsWith('/')) out = `/${out}`;
    if (!out.endsWith('/')) out = `${out}/`;
    return out;
};

const getPostHref = (post: any) => {
    if (post?.data?.originalPath) return normalizeHref(post.data.originalPath);
    return `${basePath}/${post.id}/`;
};
const isRide = (post: CollectionEntry<'blog'>) => Boolean(post.data.gpxUrl);
const getEntryType = (post: CollectionEntry<'blog'>) =>
    isRide(post) ? 'Ride' : post.data.category;
const getTypeHref = (post: CollectionEntry<'blog'>) =>
    isRide(post) ? '/rides/' : `/category/${post.data.category}/`;
const getViewCount = (post: CollectionEntry<'blog'>) =>
    viewMap.get(`${basePath}/${post.id}`) ??
    viewMap.get(`${basePath}/${post.id}/`) ??
    0;
---

<div class='grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3'>
    {
        entries.map((post) => (
            <article class='bg-card overflow-hidden rounded-lg border shadow-sm'>
                <a
                    href={getPostHref(post)}
                    class='relative block aspect-video w-full overflow-hidden'
                >
                    {(() => {
                        const src =
                            post.data.image ??
                            generatePlaceholder(post.data.title ?? post.id);
                        return (
                            <img
                                src={src}
                                alt={post.data.title || 'image'}
                                class='absolute inset-0 h-full w-full object-cover'
                                sizes='(max-width: 600px) 100vw, (max-width: 900px) 50vw, 33vw'
                            />
                        );
                    })()}
                </a>

                <div class='p-4'>
                    {getEntryType(post) && (
                        <div class='text-muted-foreground mb-2 rounded text-xs capitalize'>
                            <a href={getTypeHref(post)}>
                                {getEntryType(post)}
                            </a>
                        </div>
                    )}

                    <h3 class='mb-1 text-lg font-semibold'>
                        <a href={getPostHref(post)} class='hover:underline'>
                            {post.data.title}
                        </a>
                    </h3>

                    <p class='text-muted-foreground mb-3 text-sm'>
                        {post.data.summary}
                    </p>

                    <div>
                        <div class='mb-2 flex flex-wrap gap-2'>
                            {sortDisplayTags(post.data.tags)
                                .slice(0, 5)
                                .map((tag) => (
                                    <a
                                        href={`/tag/${tag.slug}/`}
                                        class='bg-muted-foreground text-muted rounded px-2 py-0.5 text-xs'
                                    >
                                        {tag.label}
                                    </a>
                                ))}
                        </div>

                        <div class='text-muted-foreground flex items-center justify-between text-xs'>
                            {showViews ? (
                                <span aria-label='views'>
                                    👀 {getViewCount(post).toLocaleString()}
                                </span>
                            ) : (
                                <span />
                            )}
                            <span class='text-right'>
                                <FormattedDate date={post.data.date} />
                            </span>
                        </div>
                    </div>
                </div>
            </article>
        ))
    }
</div>
