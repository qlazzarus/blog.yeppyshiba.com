---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import EntryGrid from '@/components/EntryGrid.astro';
import Pagination from '@/components/Pagination.astro';
import { POSTS_PER_PAGE } from '@/consts';
import {
    getPostsByTag,
    getTagEntries,
    getTagMetaFromPostsBySlug,
    getVisibleTagEntries,
} from '@/utils/tags';

export async function getStaticPaths() {
    const posts = await getCollection('blog');
    return getTagEntries(posts).map(({ meta }) => ({
        params: { tag: meta.slug },
    }));
}

const tag = String(Astro.params.tag);
const posts = getPostsByTag(await getCollection('blog'), tag).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

if (!posts.length) throw new Error('Tag not found');

const totalPages = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE));
const pagePosts = posts.slice(0, POSTS_PER_PAGE);
const meta = getTagMetaFromPostsBySlug(posts, tag);
const label = meta?.label ?? tag;
const isIndexable = getVisibleTagEntries(await getCollection('blog')).some(
    (entry) => entry.meta.slug === tag,
);

const title = `${label} 글 모음`;
const description = meta?.description ?? `${label} 관련 글 모음`;
const pageImage = pagePosts[0]?.data.image ?? '/images/profile-yeppyshiba.png';

const pageUrl = new URL(`/tag/${tag}/`, Astro.site).toString();

const breadcrumbs = [
    { name: 'Home', item: new URL('/', Astro.site).toString() },
    { name: 'Tag', item: new URL('/tag/', Astro.site).toString() },
    { name: label, item: pageUrl },
];
---

<BaseLayout
    title={title}
    description={description}
    image={pageImage}
    breadcrumbs={breadcrumbs}
    noindex={!isIndexable}
>
    <section>
        <h1 class='mb-4 text-center text-3xl font-bold'>
            Tag: {label}
            <span class='text-muted-foreground text-sm'>({posts.length})</span>
        </h1>

        <EntryGrid entries={pagePosts} basePath='/article' />

        <div class='mt-6'>
            <Pagination
                currentPage={1}
                totalPages={totalPages}
                basePath={`/tag/${tag}`}
                firstPagePath={`/tag/${tag}/`}
            />
        </div>
    </section>
</BaseLayout>
