---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Isometric Minesweeper';
const description =
    'Isometric 좌표계와 Phaser 4 기반 ECS 패턴으로 만든 난이도 선택형 지뢰찾기 웹게임입니다.';
---

<BaseLayout title={title} description={description}>
    <section class='mx-auto max-w-5xl space-y-5'>
        <div class='flex flex-wrap items-end justify-between gap-3'>
            <div class='space-y-2'>
                <p class='text-primary text-sm font-semibold'>Phaser 4 Lab</p>
                <h1 class='text-3xl font-bold tracking-tight'>
                    Isometric Minesweeper
                </h1>
                <p class='text-muted-foreground max-w-3xl'>
                    첫 클릭 안전 처리, 빈 칸 연쇄 오픈, 난이도 선택, 타이머를
                    붙여 플레이 가능한 Phaser 4 지뢰찾기로 다듬고 있습니다.
                </p>
            </div>
            <a
                href='/play/isometric-minesweeper/'
                class='border-border bg-card hover:bg-muted rounded border px-4 py-2 text-sm font-medium transition-colors'
            >
                가로 화면으로 열기
            </a>
        </div>

        <iframe
            src='/play/isometric-minesweeper/'
            title='Isometric Minesweeper'
            loading='lazy'
            allow='fullscreen; screen-orientation'
            class='border-border h-[min(75vh,620px)] w-full rounded-lg border bg-black'
        >
        </iframe>
    </section>
</BaseLayout>
