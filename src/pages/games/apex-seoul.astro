---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Apex Seoul';
const description =
    'Phaser 4 기반 Pseudo 3D 드리프트 레이싱 게임 Apex Seoul의 구현 실험입니다.';
---

<BaseLayout title={title} description={description}>
    <section class='mx-auto max-w-5xl space-y-5'>
        <div class='flex flex-wrap items-end justify-between gap-3'>
            <div class='space-y-2'>
                <p class='text-primary text-sm font-semibold'>Phaser 4 Lab</p>
                <h1 class='text-3xl font-bold tracking-tight'>Apex Seoul</h1>
                <p class='text-muted-foreground max-w-3xl'>
                    Pseudo 3D 카메라, 도로 투영, 드리프트 물리를 단계적으로 붙여
                    모바일 브라우저에서도 플레이 가능한 레이싱 게임으로 키우는
                    실험입니다.
                </p>
            </div>
            <a
                href='/play/apex-seoul/'
                class='border-border bg-card hover:bg-muted rounded border px-4 py-2 text-sm font-medium transition-colors'
            >
                가로 화면으로 열기
            </a>
        </div>

        <iframe
            src='/play/apex-seoul/'
            title='Apex Seoul'
            loading='lazy'
            allow='fullscreen; screen-orientation'
            class='border-border h-[min(75vh,620px)] w-full rounded-lg border bg-black'
        >
        </iframe>
    </section>
</BaseLayout>
