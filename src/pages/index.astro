---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { POSTS_PER_PAGE, SITE_DESCRIPTION } from '@/consts';
import Pagination from '@/components/Pagination.astro';
import EntryGrid from '@/components/EntryGrid.astro';

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const feedEntries = posts;

const totalPages = Math.max(1, Math.ceil(feedEntries.length / POSTS_PER_PAGE));
const pageEntries = feedEntries.slice(0, POSTS_PER_PAGE);

const title = 'Yeppyshiba Blog | Phaser 웹게임·Astro 개발·라이딩·근교 리뷰';
const description = SITE_DESCRIPTION;
const pageImage = pageEntries[0]?.data.image ?? '/images/site/profile-yeppyshiba.png';
---

<BaseLayout
    title={title}
    description={description}
    image={pageImage}
    titleTemplate={false}
>
    <section>
        <EntryGrid entries={pageEntries} basePath='/article' />
        <div class='mt-6'>
            <Pagination currentPage={1} totalPages={totalPages} basePath='/page' />
        </div>
    </section>
</BaseLayout>
