---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Tools';
const description = 'Yeppyshiba Blog에서 제공하는 계산기와 실전 도구 모음';
const breadcrumbs = [
    { name: 'Home', item: new URL('/', Astro.site).toString() },
    { name: 'Tools', item: new URL('/tools/', Astro.site).toString() },
];

const tools = [
    {
        href: '/tools/prepayment-fee-calculator/',
        title: '중도상환수수료 계산기',
        description:
            '상환 금액, 수수료율, 실행일을 기준으로 예상 중도상환수수료를 계산합니다.',
        tag: 'Finance',
    },
    {
        href: '/tools/mortgage-payment-calculator/',
        title: '대출 월 상환금 비교 계산기',
        description:
            '기존 대출과 갈아탈 대출의 월 상환금, 총 이자, 절감액을 한 번에 비교하고 갈아타기 손익을 확인합니다.',
        tag: 'Finance',
    },
];
---

<BaseLayout title={title} description={description} breadcrumbs={breadcrumbs}>
    <section class='mx-auto max-w-5xl space-y-4'>
        <div class='space-y-2'>
            <p class='text-primary text-sm font-semibold'>Useful Tools</p>
            <h1 class='text-3xl font-bold tracking-tight'>도구 모음</h1>
            <p class='text-muted-foreground'>
                실제 의사결정에 바로 쓸 수 있는 계산기와 유틸리티를 모아둔 페이지입니다.
            </p>
        </div>

        <div class='grid gap-4 md:grid-cols-2'>
            {
                tools.map((tool) => (
                    <a
                        href={tool.href}
                        class='bg-card border-border hover:border-primary/50 block rounded-2xl border p-6 transition-colors'
                    >
                        <p class='text-primary text-xs font-semibold tracking-wide uppercase'>
                            {tool.tag}
                        </p>
                        <h2 class='mt-2 text-xl font-semibold'>{tool.title}</h2>
                        <p class='text-muted-foreground mt-2 text-sm leading-6'>
                            {tool.description}
                        </p>
                    </a>
                ))
            }
        </div>
    </section>
</BaseLayout>
