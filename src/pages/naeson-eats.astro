---
import NaesonRestaurantMap from '@/components/NaesonRestaurantMap.astro';
import { naesonRestaurants } from '@/config/naesonRestaurants';
import '@/styles/global.css';

const title = '내손동 이웃 맛지도';
const description =
    '내손동 아파트 이웃들이 직접 추천한 동네 맛집을 메뉴와 카테고리별로 모아 둔 내부 공유 페이지입니다.';
const canonicalUrl = new URL('/naeson-eats/', Astro.site);
const categories = ['전체', '한식', '고기', '중식', '일식', '양식', '카페'];
const categoryCounts = Object.fromEntries(
    categories.map((category) => [
        category,
        category === '전체'
            ? naesonRestaurants.length
            : naesonRestaurants.filter((restaurant) => restaurant.category === category)
                  .length,
    ]),
);
const participatingBuildings = new Set(
    naesonRestaurants.flatMap((restaurant) => restaurant.sources),
).size;

const kakaoMapUrl = (query: string) =>
    `https://map.kakao.com/?q=${encodeURIComponent(query)}`;
---

<!doctype html>
<html lang='ko'>
    <head>
        <meta charset='utf-8' />
        <meta name='viewport' content='width=device-width, initial-scale=1' />
        <meta name='robots' content='noindex,nofollow' />
        <meta name='theme-color' content='#f6f2e8' />
        <meta name='description' content={description} />
        <link rel='canonical' href={canonicalUrl} />
        <link rel='icon' href='/images/site/akita-inu.png' />
        <title>{title}</title>
        <meta property='og:type' content='website' />
        <meta property='og:locale' content='ko_KR' />
        <meta property='og:url' content={canonicalUrl} />
        <meta property='og:site_name' content={title} />
        <meta property='og:title' content={title} />
        <meta property='og:description' content={description} />
        <meta name='twitter:card' content='summary' />
        <meta name='twitter:title' content={title} />
        <meta name='twitter:description' content={description} />
    </head>
    <body>
        <div class='site-shell'>
            <header class='topbar'>
                <a class='brand' href='#top' aria-label='맛지도 맨 위로'>
                    <span class='brand-mark' aria-hidden='true'>ㅇ</span>
                    <span>
                        <strong>우리 동네 맛지도</strong>
                        <small>내손동 이웃 공유용</small>
                    </span>
                </a>
                <button class='share-button' id='share-button' type='button'>
                    <svg viewBox='0 0 24 24' aria-hidden='true'>
                        <path
                            d='M12 16V3m0 0L7 8m5-5 5 5M5 13v6a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6'
                        ></path>
                    </svg>
                    <span>공유하기</span>
                </button>
            </header>

            <main id='top'>
                <section class='hero'>
                    <div class='hero-copy'>
                        <p class='eyebrow'>
                            <span aria-hidden='true'>✦</span> 이웃들의 진짜 추천만 모았어요
                        </p>
                        <h1>
                            오늘 뭐 먹지?<br />
                            <em>내손동 이웃 맛지도</em>
                        </h1>
                        <p class='hero-description'>
                            단톡방에 흩어져 있던 맛집을 한곳에 모았습니다.<br
                                class='desktop-break'
                            />
                            광고 없이, 우리 이웃이 직접 알려준 곳들이에요.
                        </p>
                        <dl class='stats' aria-label='맛지도 현황'>
                            <div>
                                <dt>등록 맛집</dt>
                                <dd>{naesonRestaurants.length}<span>곳</span></dd>
                            </div>
                            <div>
                                <dt>참여 동</dt>
                                <dd>{participatingBuildings}<span>개 동</span></dd>
                            </div>
                            <div>
                                <dt>최근 업데이트</dt>
                                <dd class='date-stat'>2026. 07. 24</dd>
                            </div>
                        </dl>
                    </div>
                    <div class='hero-visual' aria-hidden='true'>
                        <div class='map-grid'></div>
                        <span class='road road-one'></span>
                        <span class='road road-two'></span>
                        <span class='park'>백운호수</span>
                        <span class='map-label label-one'>내손동</span>
                        <span class='map-label label-two'>평촌</span>
                        <span class='map-label label-three'>인덕원</span>
                        <span class='map-pin pin-one'><i>🍕</i></span>
                        <span class='map-pin pin-two'><i>🍜</i></span>
                        <span class='map-pin pin-three'><i>☕</i></span>
                        <span class='map-pin pin-four'><i>🥩</i></span>
                        <span class='map-pin pin-five'><i>🍲</i></span>
                        <div class='hero-sticker'>
                            <strong>18</strong>
                            <span>이웃 맛집</span>
                        </div>
                    </div>
                </section>

                <section class='directory' aria-labelledby='directory-title'>
                    <div class='directory-heading'>
                        <div>
                            <p class='section-kicker'>NEIGHBOR PICKS</p>
                            <h2 id='directory-title'>이웃 추천 맛집</h2>
                        </div>
                        <button class='random-button' id='random-button' type='button'>
                            <span aria-hidden='true'>↻</span>
                            오늘의 메뉴 뽑기
                        </button>
                    </div>

                    <div class='controls'>
                        <label class='search-box'>
                            <svg viewBox='0 0 24 24' aria-hidden='true'>
                                <circle cx='11' cy='11' r='7'></circle>
                                <path d='m20 20-4-4'></path>
                            </svg>
                            <span class='sr-only'>맛집 또는 메뉴 검색</span>
                            <input
                                id='restaurant-search'
                                type='search'
                                placeholder='가게 이름이나 메뉴를 검색해 보세요'
                                autocomplete='off'
                            />
                            <kbd>⌘ K</kbd>
                        </label>

                        <div class='category-tabs' aria-label='음식 종류 필터'>
                            {
                                categories.map((category, index) => (
                                    <button
                                        type='button'
                                        class:list={[
                                            'category-tab',
                                            { active: index === 0 },
                                        ]}
                                        data-category={category}
                                        aria-pressed={index === 0 ? 'true' : 'false'}
                                    >
                                        <span>{category}</span>
                                        <small>{categoryCounts[category]}</small>
                                    </button>
                                ))
                            }
                        </div>
                    </div>

                    <NaesonRestaurantMap restaurants={naesonRestaurants} />

                    <div class='results-bar'>
                        <p id='results-count' aria-live='polite'>
                            <strong>{naesonRestaurants.length}</strong>곳을 보여드리고
                            있어요
                        </p>
                        <p><span class='new-dot'></span> 최근 추가된 이웃 제보</p>
                    </div>

                    <div class='restaurant-grid' id='restaurant-grid'>
                        {
                            naesonRestaurants.map((restaurant, index) => {
                                const query =
                                    restaurant.searchQuery ??
                                    `${restaurant.name} ${restaurant.location}`;
                                const searchable = [
                                    restaurant.name,
                                    restaurant.category,
                                    restaurant.location,
                                    restaurant.note,
                                    ...restaurant.menus,
                                ]
                                    .join(' ')
                                    .toLocaleLowerCase('ko');

                                return (
                                    <article
                                        class='restaurant-card'
                                        data-category={restaurant.category}
                                        data-search={searchable}
                                        data-name={restaurant.name}
                                        style={`--card-index:${index}`}
                                    >
                                        <div class='card-topline'>
                                            <span class={`food-icon tone-${index % 6}`}>
                                                {restaurant.emoji}
                                            </span>
                                            <div class='card-badges'>
                                                {restaurant.isNew && (
                                                    <span class='new-badge'>NEW</span>
                                                )}
                                                <span class='category-badge'>
                                                    {restaurant.category}
                                                </span>
                                            </div>
                                        </div>
                                        <div class='card-copy'>
                                            <h3>{restaurant.name}</h3>
                                            <p class='location'>
                                                <svg
                                                    viewBox='0 0 24 24'
                                                    aria-hidden='true'
                                                >
                                                    <path d='M20 10c0 5-8 11-8 11S4 15 4 10a8 8 0 1 1 16 0Z' />
                                                    <circle cx='12' cy='10' r='2.5' />
                                                </svg>
                                                <span>{restaurant.location}</span>
                                            </p>
                                            <div
                                                class='menu-list'
                                                aria-label='추천 메뉴'
                                            >
                                                {restaurant.menus.map((menu) => (
                                                    <span>#{menu}</span>
                                                ))}
                                            </div>
                                            <p class='recommendation'>
                                                {restaurant.note}
                                            </p>
                                        </div>
                                        <div class='card-footer'>
                                            <span class='sources'>
                                                <i aria-hidden='true'>♥</i>
                                                {restaurant.sources.join(' · ')} 제보
                                            </span>
                                            <span class='card-map-actions'>
                                                <button
                                                    type='button'
                                                    data-map-place={restaurant.name}
                                                >
                                                    지도에서
                                                </button>
                                                <a
                                                    href={kakaoMapUrl(query)}
                                                    target='_blank'
                                                    rel='noopener noreferrer'
                                                    aria-label={`${restaurant.name} 카카오맵에서 보기`}
                                                >
                                                    카카오맵
                                                    <svg
                                                        viewBox='0 0 24 24'
                                                        aria-hidden='true'
                                                    >
                                                        <path d='M7 17 17 7M8 7h9v9' />
                                                    </svg>
                                                </a>
                                            </span>
                                        </div>
                                        {restaurant.needsLocationCheck && (
                                            <span
                                                class='check-dot'
                                                title='방문 전 위치 확인 권장'
                                            />
                                        )}
                                    </article>
                                );
                            })
                        }
                    </div>

                    <div class='empty-state' id='empty-state' hidden>
                        <span aria-hidden='true'>🥄</span>
                        <h3>찾는 맛집이 아직 없어요</h3>
                        <p>다른 가게 이름이나 메뉴로 검색해 보세요.</p>
                        <button type='button' id='reset-button'>전체 목록 보기</button>
                    </div>
                </section>

                <aside class='notice'>
                    <div class='notice-icon' aria-hidden='true'>i</div>
                    <div>
                        <strong>방문하기 전에 확인해 주세요</strong>
                        <p>
                            이 페이지는 이웃 제보를 보기 좋게 모은 목록입니다. 상호,
                            위치, 메뉴와 영업시간은 바뀔 수 있으니 카드의 카카오맵
                            버튼으로 최신 정보를 확인해 주세요. 카드 모서리의 <span
                                class='inline-check-dot'></span> 표시는 위치를 한 번 더 확인하면
                            좋은 곳입니다.
                        </p>
                    </div>
                </aside>
            </main>

            <footer>
                <p>우리 동네의 맛있는 발견을 함께 나눠요.</p>
                <span>내손동 이웃 맛지도 · 링크를 아는 이웃끼리 공유</span>
            </footer>
        </div>

        <div class='toast' id='toast' role='status' aria-live='polite'></div>

        <script>
            const searchInput = document.querySelector('#restaurant-search');
            const cards = Array.from(document.querySelectorAll('.restaurant-card'));
            const categoryButtons = Array.from(
                document.querySelectorAll('.category-tab'),
            );
            const resultsCount = document.querySelector('#results-count');
            const emptyState = document.querySelector('#empty-state');
            const resetButton = document.querySelector('#reset-button');
            const randomButton = document.querySelector('#random-button');
            const shareButton = document.querySelector('#share-button');
            const toast = document.querySelector('#toast');

            let selectedCategory = '전체';
            let toastTimer;

            const normalize = (value) =>
                String(value ?? '')
                    .toLocaleLowerCase('ko')
                    .replace(/\s+/g, '');

            function applyFilters() {
                const query = normalize(searchInput?.value);
                let visibleCount = 0;

                cards.forEach((card) => {
                    const matchesCategory =
                        selectedCategory === '전체' ||
                        card.dataset.category === selectedCategory;
                    const matchesSearch = normalize(card.dataset.search).includes(
                        query,
                    );
                    const visible = matchesCategory && matchesSearch;

                    card.hidden = !visible;
                    if (visible) visibleCount += 1;
                });

                if (resultsCount) {
                    resultsCount.innerHTML = `<strong>${visibleCount}</strong>곳을 보여드리고 있어요`;
                }
                if (emptyState) emptyState.hidden = visibleCount !== 0;
                window.dispatchEvent(
                    new CustomEvent('naeson:filter', {
                        detail: {
                            names: cards
                                .filter((card) => !card.hidden)
                                .map((card) => card.dataset.name),
                        },
                    }),
                );
            }

            function selectCategory(category) {
                selectedCategory = category;
                categoryButtons.forEach((button) => {
                    const active = button.dataset.category === category;
                    button.classList.toggle('active', active);
                    button.setAttribute('aria-pressed', String(active));
                });
                applyFilters();
            }

            categoryButtons.forEach((button) => {
                button.addEventListener('click', () => {
                    selectCategory(button.dataset.category ?? '전체');
                });
            });

            searchInput?.addEventListener('input', applyFilters);

            document.querySelectorAll('[data-map-place]').forEach((button) => {
                button.addEventListener('click', () => {
                    window.dispatchEvent(
                        new CustomEvent('naeson:focus-place', {
                            detail: {
                                name: button.getAttribute('data-map-place'),
                            },
                        }),
                    );
                    document
                        .querySelector('[data-naeson-map]')
                        ?.scrollIntoView({ behavior: 'smooth', block: 'center' });
                });
            });

            resetButton?.addEventListener('click', () => {
                if (searchInput) searchInput.value = '';
                selectCategory('전체');
                searchInput?.focus();
            });

            document.addEventListener('keydown', (event) => {
                if (
                    (event.metaKey || event.ctrlKey) &&
                    event.key.toLowerCase() === 'k'
                ) {
                    event.preventDefault();
                    searchInput?.focus();
                }
            });

            randomButton?.addEventListener('click', () => {
                const visibleCards = cards.filter((card) => !card.hidden);
                if (!visibleCards.length) return;

                cards.forEach((card) => card.classList.remove('picked'));
                const picked =
                    visibleCards[Math.floor(Math.random() * visibleCards.length)];
                picked.classList.add('picked');
                picked.scrollIntoView({ behavior: 'smooth', block: 'center' });
                showToast(`오늘은 ${picked.dataset.name} 어때요?`);
                window.setTimeout(() => picked.classList.remove('picked'), 2600);
            });

            shareButton?.addEventListener('click', async () => {
                const shareData = {
                    title: document.title,
                    text: '내손동 이웃들이 추천한 맛집 목록이에요.',
                    url: window.location.href,
                };

                try {
                    if (navigator.share) {
                        await navigator.share(shareData);
                    } else {
                        await navigator.clipboard.writeText(window.location.href);
                        showToast('링크를 복사했어요');
                    }
                } catch (error) {
                    if (error instanceof DOMException && error.name === 'AbortError')
                        return;
                    showToast('주소창의 링크를 복사해 공유해 주세요');
                }
            });

            function showToast(message) {
                if (!toast) return;
                toast.textContent = message;
                toast.classList.add('show');
                window.clearTimeout(toastTimer);
                toastTimer = window.setTimeout(
                    () => toast.classList.remove('show'),
                    2200,
                );
            }
        </script>
    </body>
</html>

<style>
    :global(*) {
        box-sizing: border-box;
    }

    :global(html) {
        scroll-behavior: smooth;
        background: #f6f2e8;
    }

    :global(body) {
        margin: 0;
        min-width: 320px;
        background:
            radial-gradient(
                circle at 7% 4%,
                rgba(234, 90, 57, 0.07),
                transparent 28rem
            ),
            #f6f2e8;
        color: #243125;
        font-family:
            Pretendard,
            'Noto Sans KR',
            -apple-system,
            BlinkMacSystemFont,
            'Segoe UI',
            sans-serif;
    }

    :global(button),
    :global(input) {
        font: inherit;
    }

    :global(button),
    :global(a) {
        -webkit-tap-highlight-color: transparent;
    }

    :global([hidden]) {
        display: none !important;
    }

    .site-shell {
        min-height: 100vh;
        overflow: hidden;
    }

    .topbar {
        position: relative;
        z-index: 10;
        display: flex;
        width: min(1180px, calc(100% - 48px));
        height: 82px;
        margin: 0 auto;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid rgba(36, 49, 37, 0.12);
    }

    .brand {
        display: inline-flex;
        align-items: center;
        gap: 11px;
        color: inherit;
        text-decoration: none;
    }

    .brand-mark {
        display: grid;
        width: 38px;
        height: 38px;
        place-items: center;
        border-radius: 50% 50% 46% 54% / 54% 45% 55% 46%;
        background: #284d38;
        color: #f9e784;
        font-family: Georgia, serif;
        font-size: 21px;
        font-style: italic;
        font-weight: 800;
        transform: rotate(-7deg);
    }

    .brand strong,
    .brand small {
        display: block;
    }

    .brand strong {
        font-size: 15px;
        letter-spacing: -0.025em;
    }

    .brand small {
        margin-top: 1px;
        color: #7a8279;
        font-size: 10px;
        letter-spacing: 0.07em;
    }

    .share-button,
    .random-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 0;
        cursor: pointer;
        transition:
            transform 160ms ease,
            box-shadow 160ms ease,
            background 160ms ease;
    }

    .share-button {
        gap: 7px;
        min-height: 40px;
        padding: 0 17px;
        border: 1px solid rgba(36, 49, 37, 0.14);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.48);
        color: #344036;
        font-size: 12px;
        font-weight: 700;
    }

    .share-button svg {
        width: 15px;
        fill: none;
        stroke: currentColor;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-width: 1.8;
    }

    .share-button:hover,
    .random-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 24px rgba(38, 55, 41, 0.12);
    }

    main {
        width: min(1180px, calc(100% - 48px));
        margin: 0 auto;
    }

    .hero {
        display: grid;
        min-height: 465px;
        grid-template-columns: 1.05fr 0.95fr;
        align-items: center;
        gap: 6.5%;
        padding: 56px 0 64px;
    }

    .eyebrow,
    .section-kicker {
        margin: 0;
        color: #e05c3e;
        font-size: 11px;
        font-weight: 850;
        letter-spacing: 0.09em;
    }

    .eyebrow span {
        display: inline-block;
        margin-right: 6px;
    }

    h1 {
        margin: 18px 0 20px;
        color: #203329;
        font-family: Georgia, 'Noto Serif KR', serif;
        font-size: clamp(42px, 5vw, 66px);
        font-weight: 800;
        letter-spacing: -0.065em;
        line-height: 1.1;
    }

    h1 em {
        color: #dd5b3d;
        font-style: normal;
    }

    .hero-description {
        margin: 0;
        color: #657068;
        font-size: 15px;
        line-height: 1.75;
    }

    .stats {
        display: flex;
        gap: 0;
        margin: 30px 0 0;
    }

    .stats div {
        min-width: 112px;
        padding: 0 22px;
        border-left: 1px solid rgba(36, 49, 37, 0.14);
    }

    .stats div:first-child {
        padding-left: 0;
        border-left: 0;
    }

    .stats dt {
        margin-bottom: 5px;
        color: #8a918b;
        font-size: 10px;
        font-weight: 700;
    }

    .stats dd {
        margin: 0;
        color: #2a4535;
        font-family: Georgia, serif;
        font-size: 29px;
        font-weight: 800;
        letter-spacing: -0.04em;
    }

    .stats dd span {
        margin-left: 3px;
        font-family: inherit;
        font-size: 11px;
        letter-spacing: -0.02em;
    }

    .stats .date-stat {
        padding-top: 9px;
        font-family: inherit;
        font-size: 13px;
        letter-spacing: 0;
    }

    .hero-visual {
        position: relative;
        isolation: isolate;
        width: 100%;
        aspect-ratio: 1.32;
        overflow: hidden;
        border: 1px solid rgba(56, 75, 60, 0.11);
        border-radius: 48% 52% 43% 57% / 52% 38% 62% 48%;
        background: #e3dfc6;
        box-shadow:
            inset 0 0 80px rgba(60, 85, 61, 0.07),
            0 30px 60px rgba(65, 73, 56, 0.08);
        transform: rotate(1.5deg);
    }

    .map-grid {
        position: absolute;
        inset: -20%;
        z-index: -3;
        background-image:
            linear-gradient(rgba(91, 111, 86, 0.13) 1px, transparent 1px),
            linear-gradient(90deg, rgba(91, 111, 86, 0.13) 1px, transparent 1px);
        background-size: 42px 42px;
        transform: rotate(-11deg);
    }

    .hero-visual::before,
    .hero-visual::after {
        position: absolute;
        z-index: -2;
        border-radius: 50%;
        content: '';
    }

    .hero-visual::before {
        top: -28%;
        right: -8%;
        width: 68%;
        height: 78%;
        border: 28px solid rgba(244, 239, 209, 0.9);
        background: rgba(172, 195, 148, 0.42);
    }

    .hero-visual::after {
        bottom: -23%;
        left: -12%;
        width: 58%;
        height: 61%;
        border: 22px solid rgba(244, 239, 209, 0.85);
        background: rgba(169, 188, 132, 0.38);
    }

    .road {
        position: absolute;
        z-index: -1;
        display: block;
        border-radius: 999px;
        background: #f5efd7;
        box-shadow:
            0 0 0 1px rgba(85, 102, 75, 0.09),
            inset 0 0 0 6px #e6b75b;
    }

    .road-one {
        top: 42%;
        left: -18%;
        width: 135%;
