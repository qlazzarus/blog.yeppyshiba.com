---
import Pagination from '@/components/Pagination.astro';
import RideCardGrid from '@/components/RideCardGrid.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { readRouteStats } from '@/utils/rideStats';
import { getCollection } from 'astro:content';

const RIDES_PER_PAGE = 6;

export async function getStaticPaths() {
    const ridesPerPage = 6;
    const rides = (await getCollection('blog')).filter(
        (post) => post.data.category === 'ride' && post.data.gpxUrl,
    );
    const totalPages = Math.max(1, Math.ceil(rides.length / ridesPerPage));

    return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => ({
        params: { page: String(index + 2) },
    }));
}

const page = Number(Astro.params.page);
const rides = (await getCollection('blog'))
    .filter((post) => post.data.category === 'ride' && post.data.gpxUrl)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const totalPages = Math.max(1, Math.ceil(rides.length / RIDES_PER_PAGE));

if (Number.isNaN(page) || page < 2 || page > totalPages) {
    throw new Error('Page not found');
}

const start = (page - 1) * RIDES_PER_PAGE;
const pageRides = rides.slice(start, start + RIDES_PER_PAGE);
const rideCards = await Promise.all(
    pageRides.map(async (ride) => ({
        ride,
        stats: await readRouteStats(ride.data.gpxUrl!),
    })),
);

const title = `라이딩 기록 - ${page}페이지`;
const description = `GPX 경로, 거리, 획득고도, 평균속도와 함께 다시 보는 자전거 라이딩 기록 ${page}페이지입니다.`;
const seoTags = ['GPX', '라이딩 기록', '자전거 코스', '한강 자전거길', '로드뷰'];
const pageImage = pageRides.find((ride) => ride.data.image)?.data.image;
const breadcrumbs = [
    { name: 'Home', item: new URL('/', Astro.site).toString() },
    { name: 'Rides', item: new URL('/rides/', Astro.site).toString() },
    {
        name: `Page ${page}`,
        item: new URL(`/rides/page/${page}/`, Astro.site).toString(),
    },
];
const itemListSchema = {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: title,
    description,
    url: new URL(`/rides/page/${page}/`, Astro.site).toString(),
    numberOfItems: pageRides.length,
    itemListElement: pageRides.map((ride, index) => ({
        '@type': 'ListItem',
        position: start + index + 1,
        url: new URL(`/article/${ride.id}/`, Astro.site).toString(),
        name: ride.data.title,
        description: ride.data.summary,
        image: ride.data.image
            ? new URL(ride.data.image, Astro.site).toString()
            : undefined,
    })),
};
---

<BaseLayout
    title={title}
    description={description}
    image={pageImage}
    breadcrumbs={breadcrumbs}
    tags={seoTags}
    category='rides'
>
    <script type='application/ld+json' set:html={JSON.stringify(itemListSchema)} />
    <section class='mx-auto max-w-5xl space-y-6'>
        <div class='space-y-2'>
            <p class='text-primary text-sm font-semibold'>Cycling Routes</p>
            <h1 class='text-3xl font-bold tracking-tight'>
                라이딩 기록 {page}페이지
            </h1>
            <p class='text-muted-foreground'>
                GPX 경로와 로드뷰로 다시 보는 라이딩 로그입니다.
            </p>
            <p class='text-sm'>
                <a
                    href='/tools/gpx-analyzer/'
                    class='text-primary font-semibold hover:underline'
                >
                    내 GPX 파일 난이도 계산하기
                </a>
            </p>
        </div>

        <RideCardGrid rideCards={rideCards} />

        {
            totalPages > 1 && (
                <Pagination
                    currentPage={page}
                    totalPages={totalPages}
                    basePath='/rides/page'
                    firstPagePath='/rides/'
                />
            )
        }
    </section>
</BaseLayout>
