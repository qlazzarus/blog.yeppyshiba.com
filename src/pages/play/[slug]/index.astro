---
import { readdir, readFile } from 'node:fs/promises';
import path from 'node:path';

export async function getStaticPaths() {
    const gamesDir = path.join(process.cwd(), 'games');
    const entries = await readdir(gamesDir, { withFileTypes: true }).catch(() => []);

    return entries
        .filter((entry) => entry.isDirectory())
        .map((entry) => ({
            params: { slug: entry.name },
        }));
}

const slug = Astro.params.slug;
const gamesDir = path.join(process.cwd(), 'games');
const publicGameAssetsDir = path.join(process.cwd(), 'public', 'game-assets');

if (!slug || !/^[a-z0-9-]+$/.test(slug)) {
    Astro.response.status = 404;
}

const html =
    slug && /^[a-z0-9-]+$/.test(slug)
        ? await readFile(
              path.join(publicGameAssetsDir, slug, 'index.html'),
              'utf8',
          ).catch(() =>
              readFile(path.join(gamesDir, slug, 'dist', 'index.html'), 'utf8').catch(
                  () => null,
              ),
          )
        : null;

const assetTags = html?.match(/<(script|link)\b[^>]*(?:><\/script>|>)/g) ?? [];

const playAssetTags = slug
    ? assetTags.map((tag) => rewriteAssetTag(tag, slug))
    : assetTags;

if (!html) {
    Astro.response.status = 404;
}

function rewriteAssetTag(tag: string, slug: string) {
    return (
        tag
            // vite base가 /assets/ 로 되어 있을 때 보정
            .replaceAll('"/assets/', `"/game-assets/${slug}/assets/`)
            .replaceAll("'/assets/", `'/game-assets/${slug}/assets/`)
            // 혹시 상대경로 assets/ 로 들어온 경우 보정
            .replaceAll('"assets/', `"/game-assets/${slug}/assets/`)
            .replaceAll("'assets/", `'/game-assets/${slug}/assets/`)
    );
}
---

<!doctype html>
<html lang='ko'>
    <head>
        <meta charset='UTF-8' />
        <meta name='viewport' content='width=device-width, initial-scale=1.0' />
        <meta name='robots' content='noindex,follow' />
        <title>Isometric Minesweeper</title>
        {playAssetTags.map((tag) => <Fragment set:html={tag} />)}
    </head>
    <body>
        {html ? <div id='game' /> : 'Game build not found. Run `npm run build:games`.'}
    </body>
</html>
