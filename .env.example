# Public map integration
PUBLIC_KAKAO_MAP_API_KEY=

# Existing Google Analytics integration. Set false to disable production tracking.
PUBLIC_ANALYTICS_ENABLED=true
PUBLIC_GOOGLE_ANALYTICS_ID=

# Optional Google Search Console HTML verification token
PUBLIC_GOOGLE_SITE_VERIFICATION=

# AdSense stays disabled until every required value is supplied.
PUBLIC_ADSENSE_ENABLED=false
PUBLIC_ADSENSE_CLIENT=
PUBLIC_ADSENSE_SLOT_ARTICLE_TOP=
PUBLIC_ADSENSE_SLOT_ARTICLE_MIDDLE=
PUBLIC_ADSENSE_SLOT_ARTICLE_BOTTOM=
PUBLIC_ADSENSE_SLOT_SIDEBAR=
PUBLIC_ADSENSE_SLOT_TOOLS_BOTTOM=

# Local layout preview only. This never sends an ad request by itself.
PUBLIC_ADSENSE_DEBUG=false
