  "conversion": {
    "sessionScale": {
      "originalLateEventSec": 3000,
      "mvpTargetSessionSec": 900,
      "method": "Compress late-game timing to roughly 30% while keeping the first pressure window close to the original 60-80 second feel."
    },
    "statScale": {
      "unitHp": "Normalize ordinary enemies around 100-180 HP, defenders around 220-650 HP, and bosses around 130-900 HP.",
      "damage": "Use relative threat from original cooldown/damage fields, then flatten outliers for readable web combat.",
      "speed": "Use original move speed ranking, mapped to Phaser movement speeds around 90-125 px/s."
    },
    "economyScale": {
      "income": "Convert 70/110/170 lumber per 30 seconds into 1/2/3 egg units or equivalent cash yield.",
      "cost": "Compress Warcraft III gold/lumber costs into smaller MVP purchase prices while preserving tier gaps.",
      "penalty": "Reduce original 40% revive resource loss to 25% for shorter sessions."
    }
  },
