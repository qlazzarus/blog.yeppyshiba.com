{
    "name": "@games/apex-seoul",
    "private": true,
    "type": "module",
    "version": "0.0.1",
    "game": {
        "title": "Apex Seoul",
        "eyebrow": "Phaser 4 Lab",
        "description": "Phaser 4 기반 Pseudo 3D 드리프트 레이싱 게임 Apex Seoul의 구현 실험입니다.",
        "summary": "Pseudo 3D 카메라, 도로 투영, 드리프트 물리를 단계적으로 붙여 모바일 브라우저에서도 플레이 가능한 레이싱 게임으로 키우는 실험입니다."
    },
    "scripts": {
        "analyze:drive-telemetry": "node scripts/analyze-drive-telemetry.mjs",
        "dev": "vite --host 0.0.0.0",
        "build": "vite build",
        "build:parallax-assets": "node scripts/build-parallax-assets.mjs",
        "clean:vehicle-sprite-sheet": "node scripts/clean-vehicle-sprite-sheet.mjs",
        "download:sketchfab-model": "node scripts/download-sketchfab-model.mjs",
        "download:vehicles": "node scripts/download-kenney-car-kit.mjs",
        "export:vehicle-atlas": "node scripts/export-vehicle-atlas.mjs",
        "extract:bugak-reference": "node scripts/extract-bugak-ridge-reference.mjs",
        "finalize:vehicle-sprite-sheet": "node scripts/finalize-vehicle-sprite-sheet.mjs",
        "optimize:real-vehicle-models": "node scripts/optimize-real-vehicle-models.mjs",
        "qa:drive-telemetry": "node scripts/capture-drive-telemetry.mjs",
        "qa:handling-matrix": "node scripts/run-handling-matrix.mjs",
        "qa:handling-sim": "node scripts/simulate-handling-matrix.mjs",
        "qa:camera-effects": "node scripts/simulate-camera-effects.mjs",
        "qa:corner-speed-sense": "node scripts/audit-corner-speed-sense.mjs",
        "qa:outrun-unit-scale": "node scripts/audit-outrun-unit-scale.mjs",
        "qa:corner-demand-sweep": "node scripts/simulate-corner-demand-sweep.mjs",
        "qa:guardrail-collision": "node scripts/simulate-guardrail-collision.mjs",
        "qa:guardrail-projection": "node scripts/simulate-guardrail-screen-projection.mjs",
        "qa:guardrail-projection-runtime": "node scripts/audit-guardrail-projection-runtime.mjs",
        "qa:handling-relations": "node scripts/audit-handling-relations.mjs",
        "qa:headlight-profiles": "tsx scripts/audit-headlight-profiles.ts",
        "qa:low-speed-steering": "node scripts/simulate-low-speed-steering.mjs",
        "qa:powerband-reference": "node scripts/audit-powerband-reference.mjs",
        "qa:road-rhythm": "node scripts/audit-road-rhythm.mjs",
        "qa:road-width": "node scripts/audit-road-width.mjs",
        "qa:speed-cue": "node scripts/simulate-speed-cue.mjs",
        "qa:speed-handling-sweep": "node scripts/simulate-speed-handling-sweep.mjs",
        "qa:speed-presentation-sweep": "node scripts/simulate-speed-presentation-sweep.mjs",
        "qa:top-speed-equilibrium": "node scripts/simulate-top-speed-equilibrium.mjs",
        "qa:top-speed-force-budget": "node scripts/design-top-speed-force-budget.mjs",
        "qa:top-speed-calibration": "node scripts/audit-top-speed-calibration.mjs",
        "qa:top-speed-regression": "node scripts/audit-top-speed-regression.mjs",
        "qa:sh7-telemetry": "node scripts/audit-sh7-runtime.mjs",
    "qa:standing-start": "node scripts/simulate-standing-start.mjs",
    "qa:understeer-visual": "node scripts/simulate-understeer-visual.mjs",
        "qa:vehicle-road-scale": "node scripts/simulate-vehicle-road-scale.mjs",
        "qa:ft86-runtime-colors": "node scripts/capture-runtime-vehicle-qa.mjs --vehicle ft86-retro --vehicle-colors blue,black,silver,red,yellow --output-dir assets/vehicles/generated/runtime-qa/ft86-retro-colors",
        "pixel-pass:vehicle-sheet": "node scripts/pixel-pass-vehicle-sheet.mjs",
        "postprocess:ft86-retro": "node scripts/postprocess-ft86-retro-sheet.mjs",
        "preview": "vite preview --host 0.0.0.0",
        "prepare:vehicle-sprite-sheet": "node scripts/prepare-vehicle-sprite-sheet.mjs",
        "qa:runtime-vehicle": "node scripts/capture-runtime-vehicle-qa.mjs",
        "qa:vehicle-steering": "node scripts/qa-vehicle-steering.mjs",
        "render:real-vehicle-pocs": "node scripts/render-real-vehicle-pocs.mjs",
        "render:vehicle-pose-sheet": "node scripts/render-vehicle-pose-sheet.mjs",
        "render:vehicles": "node scripts/render-vehicle-sprites.mjs",
        "score:vehicle-sheet": "node scripts/score-vehicle-sprite-sheet.mjs"
    },
    "dependencies": {
        "phaser": "^4.1.0",
        "three": "^0.184.0"
    },
    "devDependencies": {
        "sharp": "^0.34.5",
        "typescript": "^5.9.3",
        "vite": "^7.3.0"
    }
}
